# Shopify Storefront API Configuration
# Required: Get these from your new Shopify store admin dashboard
# Admin → Apps → Develop Apps → Configure Storefront API → Public access tokens

# Your Shopify store domain (e.g., mystore.myshopify.com)
PUBLIC_STORE_DOMAIN=your-store.myshopify.com

# Storefront API access token (public token for frontend)
PUBLIC_STOREFRONT_API_TOKEN=your_storefront_api_token_here

# Storefront API version (matches Hydrogen version)
PUBLIC_STOREFRONT_API_VERSION=2026-04

# Checkout domain (usually same as store domain)
PUBLIC_CHECKOUT_DOMAIN=your-store.myshopify.com

# Storefront ID (found in Hydrogen/Storefront API settings)
PUBLIC_STOREFRONT_ID=gid://shopify/Shop/your_shop_id

# Session secret (for customer authentication)
SESSION_SECRET=your_session_secret_here_at_least_32_chars

# Deployment environment
NODE_ENV=development
